{
  "expo": {
    "name": "Ca passe ou pas",
    "slug": "capasseoupas",
    "version": "2.0.9",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "sdkVersion": "54.0.0",
    "scheme": "rork-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "buildNumber": "9",
      "bundleIdentifier": "app.rork.capasseoupas",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Capasseoupas utilise votre position pour afficher les commerces acceptant ou refusant American Express autour de vous et calculer la distance jusqu'à ces établissements."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "app.rork.capasseoupas"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://rork.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "Capasseoupas utilise cet identifiant pour améliorer votre expérience et vous proposer des contenus pertinents."
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "iosAppId": "ca-app-pub-6551125672569348~6106093593"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
